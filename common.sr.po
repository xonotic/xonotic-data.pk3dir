#, no-c-format
msgid "@!#%'n Tuba Throwing"
msgstr "@!#%'n бацање трубе"

#: qcsrc/common/mapinfo.qh:94
#: qcsrc/menu/xonotic/dialog_multiplayer_create.qc:107
msgid "Frag limit:"
msgstr "Граница фреговања:"

#: qcsrc/common/mapinfo.qh:94
msgid "The amount of frags needed before the match will end"
msgstr "Број фрегова потребних пре него што се игра заврши"

#: qcsrc/common/minigames/cl_minigames.qc:285
msgid "Spectators:"
msgstr "Посматрачи:"

#: qcsrc/common/minigames/cl_minigames.qc:421
msgid "It's your turn"
